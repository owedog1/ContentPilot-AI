# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/contentpilot
# Or use SQLite for development
# DATABASE_URL=sqlite:///./contentpilot.db

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# Application Configuration
APP_NAME=ContentPilot AI
APP_ENV=development
DEBUG=True
FRONTEND_URL=http://localhost:3000

# Redis Configuration (for rate limiting)
REDIS_URL=redis://localhost:6379/0

# Email Configuration (optional for support)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
